# ============================================================
# Compliflow — Environment Variables
# ============================================================
# Kopiere diese Datei zu .env.local und fülle die echten Werte ein.
# NIEMALS .env.local committen.
# ============================================================

# === SUPABASE (DB + Auth + Storage) ===
# EU-Region (Frankfurt) — DSGVO Pflicht!
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# === STRIPE (Payments) ===
# Test-Mode während Build, Live nur am Launch-Tag tauschen
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Product/Price IDs (nach Anlage im Dashboard)
STRIPE_PRICE_AVV_PRO_ONETIME=price_xxx
STRIPE_PRICE_AVV_PRO_AGENCY=price_xxx
STRIPE_PRICE_BUNDLE_AVV_VVT=price_xxx
STRIPE_PRICE_SUITE_LIFETIME=price_xxx

# === RESEND (Email) ===
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hello@compliflow.de

# === PLAUSIBLE (Analytics) ===
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=compliflow.de

# === POSTHOG (Heatmaps + Funnels) ===
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# === APP ===
NEXT_PUBLIC_APP_URL=https://compliflow.de
NEXT_PUBLIC_SITE_NAME=Compliflow

# === DOCUSIGN (Phase 2 — Pro-Agency-Feature) ===
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY=
