# ============================================================
# Compliflow — Environment Variables
# ============================================================
# Kopiere diese Datei zu .env.local und fülle die echten Werte ein.
# NIEMALS .env.local committen!
# Für Coolify: alle Variablen direkt in den Environment-Settings eintragen.
#
# Verhalten bei Fehlen wird zentral in lib/env.ts gesteuert:
#   - 9 Variablen sind in Production PFLICHT (REQUIRED_IN_PRODUCTION).
#     Fehlt eine davon, wirft validateEnv() beim Server-Start
#     (instrumentation.ts) → der Container startet GAR NICHT.
#   - In Dev (NODE_ENV != production) gibt es nur eine gelbe Warnung,
#     die meisten Routen laufen im Mock-Modus weiter.
# ============================================================


# ============================================================
# PFLICHT IN PRODUCTION
# Fehlt eine dieser 9 → Container startet nicht (lib/env.ts wirft).
# ============================================================

# === STRIPE (Payments) ===
# Lokal: leer lassen → Mock-Modus aktiv (kein Stripe-Account nötig, kein echter Checkout).
# Production: Live-Keys eintragen → echtes Stripe.
# Fehlt in Prod: Server-Start bricht ab. Watermark-Checkout (app/api/stripe/checkout)
# antwortet zusätzlich mit 500, wenn Key oder Price-ID fehlen.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price-ID für "Wasserzeichen entfernen" (einmalige Zahlung).
# Im Stripe Dashboard das Produkt anlegen und die price_xxx-ID hier eintragen.
# Dies ist die EINZIGE aktuell genutzte Price-ID (Pro-Tier wurde verworfen,
# siehe docs/MONETIZATION-STRATEGY.md).
# Fehlt in Prod: Server-Start bricht ab; Checkout-Route liefert 500.
STRIPE_PRICE_WATERMARK_REMOVAL=price_xxx

# === RESEND (Transaktions-E-Mails) ===
# Gebraucht für: Zahlungsbestätigung + Download-Link nach Stripe-Zahlung.
# Domain compliflow.de muss in Resend verifiziert sein (DNS-Einträge).
# Fehlt in Prod: Server-Start bricht ab.
RESEND_API_KEY=re_xxx

# === APP-URL ===
# Basis-URL für DOI-Bestätigungslinks, Brevo-Redirects, Stripe-Erfolgsseiten.
# Fehlt in Prod: Server-Start bricht ab. (In Dev Fallback http://localhost:3000.)
NEXT_PUBLIC_APP_URL=https://compliflow.de

# === DOUBLE OPT-IN (Waitlist / DOI-Token) ===
# HMAC-Geheimnis für Bestätigungs-Links (lib/doi-token.ts). Mind. 32 Zeichen zufällig.
# Generieren: openssl rand -hex 32
# Fehlt in Prod: Server-Start bricht ab. Token-Erstellung/-Prüfung wirft "DOI_SECRET missing".
DOI_SECRET=

# === BREVO (Email-Marketing, Double-Opt-In) ===
# DSGVO-konformer Newsletter-Dienst (EU-Server, DPA). DOI ist Pflicht (UWG §7).
# BREVO_API_KEY:        API-Key aus dem Brevo-Dashboard.
# BREVO_LIST_ID:        ID der Newsletter-Liste (Zahl).
# BREVO_DOI_TEMPLATE_ID: ID des Double-Opt-In-Templates in Brevo (Zahl).
# Fehlt in Prod: Server-Start bricht ab. Ohne API-Key läuft /api/brevo/subscribe
# in Dev im Mock-Modus (keine echte Email).
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_DOI_TEMPLATE_ID=


# ============================================================
# OPTIONAL — sauberer Fallback, kein Start-Abbruch
# ============================================================

# === UPSTASH REDIS (persistentes Rate-Limiting) ===
# Wenn BEIDE gesetzt: API-Rate-Limits überleben Container-Restarts (lib/rate-limit.ts).
# Fehlt (eine oder beide): In-Memory-Fallback aktiv — funktioniert, aber Limits
# resetten bei jedem Restart. In Prod wird eine Warnung geloggt.
# Einrichten: https://upstash.com → Redis-DB (Region EU-West) → REST-URL + Token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === SUPABASE (Waitlist-Speicherung) ===
# Wenn gesetzt: bestätigte Waitlist-Einträge in Supabase.
# Fehlt: Fallback auf lokale Datei .data/waitlist-confirmed.jsonl.
# NUR ANON-Key verwenden! (kein Service Role Key)
# Tabellen-Schema: id serial, email text unique, source text, confirmed bool, confirmed_at timestamptz
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ============================================================
# PHASE 2 — noch nicht im Code verdrahtet
# ============================================================

# PostHog — erst nötig wenn Funnel-Tracking eingebaut wird
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# DocuSign — Phase 2 Pro-Agency-Feature (digitale Signatur)
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_USER_ID=
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_PRIVATE_KEY=


# ============================================================
# Hinweis: Folgende Variablen wurden aus dieser Vorlage ENTFERNT,
# weil sie im Code NICHT (mehr) gelesen werden:
#   - NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY  (kein Stripe.js Client im Einsatz)
#   - STRIPE_PRICE_AVV_PRO / STRIPE_PRICE_VVT_PRO  (Pro-Tier verworfen)
#   - NEXT_PUBLIC_PLAUSIBLE_DOMAIN  (Plausible-Domain ist in app/layout.tsx hardcoded)
# BUILD_STANDALONE / NODE_ENV / NEXT_RUNTIME werden vom Build/Next.js
# automatisch gesetzt und gehören nicht hierher (siehe CLAUDE.md → Build-System).
# ============================================================
