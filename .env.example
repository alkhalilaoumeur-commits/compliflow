# ============================================================
# Compliflow — Environment Variables
# ============================================================
# Kopiere diese Datei zu .env.local und fülle die echten Werte ein.
# NIEMALS .env.local committen!
# Für Coolify: alle Variablen direkt in den Environment-Settings eintragen.
# ============================================================

# === STRIPE (Payments) ===
# Lokal: leer lassen → Mock-Modus aktiv (kein Stripe-Account nötig, kein echter Checkout)
# Production (Coolify): Live-Keys eintragen → echtes Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Stripe Price-IDs — nach Anlage im Stripe Dashboard eintragen
# Dashboard: Produkt "AVV Pro" + "VVT Pro" anlegen, je 29 EUR einmalig (kein Abo!)
STRIPE_PRICE_AVV_PRO=price_xxx
STRIPE_PRICE_VVT_PRO=price_xxx

# === RESEND (Transaktions-E-Mails) ===
# Wird gebraucht für: Zahlungsbestätigung + Download-Link nach Stripe-Zahlung
# Domain compliflow.de muss in Resend verifiziert sein (DNS-Einträge)
RESEND_API_KEY=re_xxx

# === APP ===
NEXT_PUBLIC_APP_URL=https://compliflow.de

# === PLAUSIBLE (Cookie-lose Analytics — kein Cookie-Banner nötig) ===
# Domain muss in Plausible-Dashboard eingetragen sein
# Aktuell im layout.tsx hardcoded auf compliflow.de — ENV wird nur für future use gebraucht
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=compliflow.de

# === PHASE 2 (noch nicht aktiv) ===
# Supabase — erst nötig wenn Auth + Datenbank eingebaut wird
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
# SUPABASE_SERVICE_ROLE_KEY=eyJh...

# PostHog — erst nötig wenn Funnel-Tracking eingebaut wird
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# DocuSign — Phase 2 Pro-Agency-Feature (digitale Signatur)
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_USER_ID=
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_PRIVATE_KEY=
