{
  "name": "compliflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "rm -rf .next/standalone .next/server .next/cache/webpack",
    "dev": "next dev",
    "dev:fresh": "lsof -ti:3000 | xargs kill -9 2>/dev/null; rm -rf .next && next dev",
    "kill": "lsof -ti:3000 | xargs kill -9 2>/dev/null; echo 'Port 3000 free'",
    "build": "next build",
    "build:standalone": "BUILD_STANDALONE=1 next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .next node_modules/.cache"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@react-pdf/renderer": "^4.5.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.77.0",
    "resend": "^6.12.4",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
